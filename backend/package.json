{
  "name": "esraa-portfolio-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute esraa-portfolio-db --file=schema.sql",
    "db:seed": "wrangler d1 execute esraa-portfolio-db --file=seed.sql",
    "db:init:remote": "wrangler d1 execute esraa-portfolio-db --remote --file=schema.sql",
    "db:seed:remote": "wrangler d1 execute esraa-portfolio-db --remote --file=seed.sql"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240725.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.65.0"
  }
}
